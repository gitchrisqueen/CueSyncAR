    "No rails/pockets/balls on the path: single roll segment, single rest event."
  ],
  "table": {
    "size": "nineFoot"
  },
  "config": {
    "rollingDeceleration": 0.5,
    "cushionRestitution": 0.75,
    "ballBallRestitution": 0.96,
    "restSpeed": 0.05
  },
  "balls": [
    {
      "id": 0,
      "kind": "cue",
      "position": [
        -0.5,
        0.0
      ]
    }
  ],
  "aim": {
    "origin": [
      -0.5,
      0.0
    ],
    "direction": [
      1,
      0
    ]
  },
  "options": {
    "initialSpeed": 1.0,
    "maxEvents": 8
  },
  "tolerance": 1e-09,
  "expected": {
    "segments": [
      {
        "ball": 0,
        "kind": "roll",
        "start": [
          -0.5,
          0.0
        ],
        "end": [
          0.5,
          0.0
        ],
        "entrySpeed": 1.0
      }
    ],
    "events": [
      {
        "type": "rest",
        "ball": 0,
        "point": [
          0.5,
          0.0
        ]
      }
    ],
    "pocketedBalls": []
  }
}
